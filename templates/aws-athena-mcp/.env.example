AWS_REGION=us-east-1
ZEUZ_AWS_ALLOWED_ACCOUNT=123456789012
ZEUZ_ATHENA_WORKGROUP=zeuz-read-only
ZEUZ_ATHENA_CATALOG=AwsDataCatalog
ZEUZ_ATHENA_DATABASE_ALLOWLIST=analytics,reporting
ZEUZ_ATHENA_MAX_ROWS=500
ZEUZ_ATHENA_TIMEOUT_MS=60000
# Leave empty when the workgroup uses Athena managed query results.
ZEUZ_ATHENA_OUTPUT_LOCATION=
